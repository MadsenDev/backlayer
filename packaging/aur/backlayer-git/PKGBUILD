# Maintainer: Backlayer contributors

pkgname=backlayer-git
pkgver=r0.g0000000
pkgrel=1
pkgdesc="Animated wallpaper runtime for Linux with Hyprland and KDE Plasma integration"
arch=("x86_64")
url="https://github.com/MadsenDev/backlayer"
license=("MIT")
install="backlayer.install"
depends=(
  "ffmpeg"
  "gcc-libs"
  "glib2"
  "hicolor-icon-theme"
  "libxkbcommon"
  "wayland"
  "webkit2gtk-4.1"
  "zstd"
)
makedepends=(
  "cargo"
  "desktop-file-utils"
  "git"
  "nodejs"
  "pnpm"
)
optdepends=(
  "hyprland: wlroots layer-shell wallpaper runtime"
  "plasma-desktop: KDE Plasma wallpaper plugin integration"
)
provides=("backlayer")
conflicts=("backlayer")
source=("git+https://github.com/MadsenDev/backlayer.git")
sha256sums=("SKIP")

pkgver() {
  cd "${srcdir}/backlayer"
  printf "r%s.g%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
  cd "${srcdir}/backlayer"
  bash packaging/arch/build-runtime.sh "${srcdir}/backlayer"
}

package() {
  cd "${srcdir}/backlayer"
  bash packaging/arch/install-runtime.sh "${srcdir}/backlayer" "${pkgdir}"
}
